menu "TrailMate T-Display-P4"

    choice TRAIL_MATE_T_DISPLAY_P4_PANEL
        prompt "Display panel"
        default TRAIL_MATE_T_DISPLAY_P4_PANEL_HI8561

        config TRAIL_MATE_T_DISPLAY_P4_PANEL_HI8561
            bool "HI8561 + HI8561 touch"

        config TRAIL_MATE_T_DISPLAY_P4_PANEL_RM69A10
            bool "RM69A10 + GT9895 touch"
    endchoice

    choice TRAIL_MATE_T_DISPLAY_P4_PIXEL_FORMAT
        prompt "Display pixel format"
        default TRAIL_MATE_T_DISPLAY_P4_PIXEL_FORMAT_RGB565

        config TRAIL_MATE_T_DISPLAY_P4_PIXEL_FORMAT_RGB565
            bool "RGB565"

        config TRAIL_MATE_T_DISPLAY_P4_PIXEL_FORMAT_RGB888
            bool "RGB888"
    endchoice

    config TRAIL_MATE_T_DISPLAY_P4_LVGL_BUFFER_LINES
        int "LVGL draw buffer height"
        range 32 200
        default 80
        help
            Number of scanlines stored in each LVGL draw buffer.

endmenu
